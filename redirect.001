  <script>
    function getMobileOS() {
      const ua = navigator.userAgent;

      if (/Android/i.test(ua)) {
        return "android";
      }
      const isIOS =
        /iPhone|iPad|iPod/i.test(ua) ||
        (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1);
      if (isIOS) {
        return "ios";
      }
      return "other";
    }
    let hasAppOpened = false;
    const timeout = 3000;
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) {
        hasAppOpened = true;
      }
    });
    window.addEventListener('blur', function () {
      hasAppOpened = true;
    });
    function getParam(name = 'gid', url = window.location.search) {
      var reg = new RegExp("(^|&)" + name + "=([^&]*)(&|$)", "i");
      var r = (url || window.location.search).substr(1).match(reg);
      if (r != null) return decodeURIComponent(r[2]); return null;
    }
    const android_link =  getParam("android_link") || 'intent:\/\/castbox.fm\/ep\/516147884#Intent;scheme=https;package=fm.castbox.audiobook.radio.podcast;S.browser_fallback_url=https:\/\/play.google.com\/store\/apps\/details?id=fm.castbox.audiobook.radio.podcast;S.uri=https:\/\/castbox.fm\/ep\/516147884;S.v=v1;l.ct=1780350610008;S.source=shortlink;end';
    const ios_link = getParam("ios_link") || 'https:\/\/castbox.fm\/appstore?link=https%3A%2F%2Fcastbox.fm%2Fep%2F516147884\u0026isi=1243410543\u0026ibi=fm.castbox.audiobook.radio.podcast\u0026v=v1\u0026ct=1780350610008\u0026source=shortlink';
    const ap_isi = getParam("ap_isi") || '1243410543';
    const web_link = getParam("web_link") || 'https:\/\/castbox.fm\/ep\/516147884';
    const gp_package = getParam('gp_package') || 'fm.castbox.audiobook.radio.podcast';
    const mobileOS = getMobileOS();
    function openAndroidApp() {
      if (android_link) {
        location.replace(android_link);
        setTimeout(function () {
          if (!hasAppOpened) {
            location.replace(`https://play.google.com/store/apps/details?id=${gp_package}`);
          }
        }, timeout);
      }
    }
    function openIOSAPP() {
      if (ios_link) {
        location.replace(ios_link);
      }
    }
    function openApp() {
      if (mobileOS === 'android') {
        openAndroidApp();
      } else if (mobileOS === 'ios') {
        openIOSAPP();
      } else if (web_link) {
        
        location.replace(web_link);
      }
    }
    if (mobileOS === 'android' && android_link) {
      openAndroidApp();
    } else if (mobileOS === 'ios' && ios_link) {
      
    } else if (web_link) {
      location.replace(web_link);
    }
  </script>
